{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.schema.json",
  // Use a stock image + features because it uses less storage quota in Codespaces.
  "image": "mcr.microsoft.com/devcontainers/python:trixie",
  "features": {
    "ghcr.io/devcontainers/features/git-lfs:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/helpers4/devcontainer/shell-history-per-project:1": {},
    // Node for various dev tools
    "ghcr.io/devcontainers/features/node:2": {},
    // uv for project package manamgent
    "ghcr.io/devcontainers-extra/features/uv:1": {},
    "ghcr.io/devcontainer-community/devcontainer-features/jonas-tig:1": {},
    "ghcr.io/devcontainers-extra/features/claude-code:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Agent-friendly tools
    "ghcr.io/jsburckhardt/devcontainer-features/fd:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/fzf:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/ripgrep:1": {},
    "ghcr.io/jsburckhardt/devcontainer-features/bat:1": {}
  },
  "mounts": [
    // Persist some profile directories. Can't mount the entire home directory because of permissions issues.
    "source=ssh,target=/home/vscode/ssh,type=volume",
    // Persistent volume for the UV cache; can be shared with other containers
    "source=uv-cache,target=/home/vscode/.cache/uv,type=volume",
    // Persistent volume for the virtual environment
    "source=${localWorkspaceFolderBasename}-venv,target=${containerWorkspaceFolder}/.venv,type=volume",
    "source=${localWorkspaceFolderBasename}-node,target=${containerWorkspaceFolder}/node_modules,type=volume",
    // Persist user config across container rebuilds
    "source=${localWorkspaceFolderBasename}-marimo-config,target=/home/vscode/.config/marimo,type=volume",
    "source=${localWorkspaceFolderBasename}-claude-config,target=/home/vscode/.claude,type=volume"
  ],
  "containerEnv": {
    "UV_CACHE_DIR": "/home/vscode/.cache/uv",
    // Copy instead of hardlinking due to separate volumes
    "UV_LINK_MODE": "copy",
    // Don't write .pyc files for project modules: avoids conflicts when the
    // same source tree is run from both the container (Linux) and the host
    // (macOS/Windows). Previously we used PYTHONPYCACHEPREFIX, but marimo
    // mirrors its __marimo__/ output dir under that prefix too, hiding the
    // notebook auto-export files. Pair with UV_COMPILE_BYTECODE so installed
    // packages in .venv are still pre-compiled at install time.
    "PYTHONDONTWRITEBYTECODE": "1",
    "UV_COMPILE_BYTECODE": "1"
  },
  "remoteEnv": {
    // Project tool wrappers (marimo, ruff, ty, modal) that run via `uv run`
    "PATH": "${containerWorkspaceFolder}/bin:${containerEnv:PATH}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // "anthropic.claude-code",  // Provided by claude-code feature
        "astral-sh.ty",
        "bierner.github-markdown-preview",
        "charliermarsh.ruff",
        "esbenp.prettier-vscode",
        // "GitHub.copilot-chat",
        // "GitHub.copilot",
        "github.vscode-github-actions",
        "marimo-team.vscode-marimo",
        "mechatroner.rainbow-csv",
        "ms-python.python",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "tamasfe.even-better-toml"
      ]
    }
  },
  "postCreateCommand": "./.devcontainer/post-create.sh"
}
