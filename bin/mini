#!/usr/bin/env bash
# Pin to this project so the wrapper works from any cwd, then run the `mini`
# console-script (see [project.scripts]). The store is found at the project root
# regardless of where you invoke this from (mini.runs.data_root).
# MINI_PROG tells the CLI how it was invoked, so its hints are copy-pasteable.
export MINI_PROG="$0"
exec uv run --project "${0%/*}/.." mini "$@"
