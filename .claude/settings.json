{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "sandbox": {
        "network": {
            "allowedDomains": [
                "*.pytorch.org",
                "storage.googleapis.com",
                "modal.com",
                "*.modal.com",
                "*.modal.run",
                "*.modal-storage.com",
                "huggingface.co",
                "*.xethub.hf.co",
                "*.cdn.hf.co",
                "cdn.jsdelivr.net"
            ]
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-check.sh"
                    }
                ]
            }
        ]
    }
}
